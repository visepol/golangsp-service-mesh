# Pinned versions for reproducibility (live-demo safety). Bump deliberately.
# Sourced by the Makefile; also documents what the project was tested against.

GO_VERSION=1.23

# Local Kubernetes (k3s in Docker via k3d).
K3D_VERSION=v5.7.5
K3S_IMAGE=rancher/k3s:v1.31.5-k3s1
KUBECTL_VERSION=v1.31.5

# Istio control plane + sidecar (installed with the 'minimal' profile).
ISTIO_VERSION=1.24.3

# Cluster + image names.
CLUSTER_NAME=svcmesh-demo
SERVER_IMAGE=go-api:local
CLIENT_IMAGE=go-client:local
