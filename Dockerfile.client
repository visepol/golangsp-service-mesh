# Multi-stage build so the host needs only Docker (no Go toolchain installed).
ARG GO_VERSION=1.23
FROM golang:${GO_VERSION} AS build
WORKDIR /src

# Cache deps first.
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" -o /out/client ./cmd/client

FROM gcr.io/distroless/static:nonroot
COPY --from=build /out/client /client
USER nonroot:nonroot
ENTRYPOINT ["/client"]
